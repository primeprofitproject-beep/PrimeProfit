rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.get('email', '').lower() == 'primeprofitproject@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isNotBlocked() {
      // Admins are never blocked.
      return isAdmin() || (
        isSignedIn() && 
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'active') == 'active')
      );
    }

    // --- PUBLIC ACCESS ---
    match /referralCodes/{code} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /config/global {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && (!exists(/databases/$(database)/documents/config/global) || get(/databases/$(database)/documents/config/global).data.get('firstUserCreated', false) == false));
    }

    // --- USER RULES ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 50 &&
             data.email is string && data.email.size() <= 100 &&
             data.referralCode is string && data.referralCode.size() <= 20 &&
             (data.referredBy == null || (data.referredBy is string && data.referredBy.size() <= 128)) &&
             data.balance is number && data.balance >= 0 &&
             data.totalEarnings is number &&
             data.teamEarnings is number &&
             data.rewards is number &&
             (!('todayEarnings' in data) || data.todayEarnings is number) &&
             data.status in ['active', 'blocked'] &&
             data.isAdmin is bool &&
             data.createdAt is timestamp &&
             (!('lastCycleAt' in data) || data.lastCycleAt is timestamp) &&
             (!('uplinePath' in data) || data.uplinePath is list) &&
             (!('teamStats' in data) || data.teamStats is map);
    }

    match /users/{userId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().balance == 0 && incoming().status == 'active' &&
                    incoming().totalEarnings == 0 &&
                    (incoming().isAdmin == (request.auth.token.get('email', '').lower() == 'primeprofitproject@gmail.com'));
      
      allow update: if isAdmin() || (
        isSignedIn() && isNotBlocked() && (
          (isOwner(userId) && isValidUser(incoming()) && (
            // Action: Profile Update
            (incoming().diff(existing()).affectedKeys().hasOnly(['username', 'email'])) ||
            // Action: Instant Earning Update
            (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'totalEarnings', 'todayEarnings', 'lastCycleAt'])) ||
            // Action: Reward/Adjustment (Historical Support)
            (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'totalEarnings', 'todayEarnings'])) ||
            (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'rewards', 'totalEarnings', 'todayEarnings'])) ||
            // Action: Withdrawal Request (Balance only deduction)
            (incoming().diff(existing()).affectedKeys().hasOnly(['balance']))
          )) ||
          // Action: Team Reward or Stats Update (Updater must be a referral of the target user)
          (
            (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'totalEarnings', 'teamEarnings', 'todayEarnings']) ||
             incoming().diff(existing()).affectedKeys().hasOnly(['teamStats'])) &&
            (
              userId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('referredBy', null) ||
              userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('uplinePath', [])
            )
          )
        )
      );
      allow delete: if isAdmin();
    }

    // --- TRANSACTIONS RULES ---
    function isValidTransaction(data) {
      return data.userId is string && 
             (data.userId == request.auth.uid || isAdmin() || (data.type == 'team_reward' && data.userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('uplinePath', []))) &&
             data.amount is number && data.amount >= 0 &&
             data.type in ['deposit', 'withdrawal', 'withdrawal_request', 'cycle_profit', 'cycle_earning', 'reward', 'team_reward', 'withdrawal_refund', 'admin_adjustment'] &&
             data.status in ['pending', 'completed', 'approved', 'rejected'] &&
             data.timestamp is timestamp &&
             (!('walletAddress' in data) || (data.walletAddress is string && data.walletAddress.size() >= 10 && data.walletAddress.size() <= 200));
    }

    match /transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isNotBlocked() && isValidTransaction(incoming());
      allow update, delete: if isAdmin();
    }

    // --- CYCLES RULES ---
    function isValidCycle(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.balanceAtStart is number && data.balanceAtStart >= 15 &&
             data.profitPercentage is number &&
             data.profitAmount is number && data.profitAmount >= 0 &&
             data.startTime is timestamp && data.endTime is timestamp &&
             data.status in ['active', 'completed'] &&
             (!('completedAt' in data) || data.completedAt is timestamp);
    }

    match /cycles/{cycleId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isNotBlocked() && isValidCycle(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && isNotBlocked() && existing().userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedAt']) &&
        incoming().status == 'completed'
      );
      allow delete: if isAdmin();
    }

    // --- RESERVE RULES (Legacy) ---
    function isValidReserve(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 30 &&
             data.profit is number &&
             data.startTime is timestamp &&
             data.endTime is timestamp &&
             data.status in ['active', 'completed'];
    }

    match /reserves/{reserveId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isNotBlocked() && isValidReserve(incoming()) && incoming().status == 'active';
      allow update, delete: if isAdmin();
    }

    // --- DEPOSIT RULES ---
    function isValidDeposit(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.timestamp is timestamp;
    }

    match /deposits/{depositId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isNotBlocked() && isValidDeposit(incoming()) && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // --- WITHDRAWAL RULES ---
    function isValidWithdrawal(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 30 &&
             data.walletAddress is string && data.walletAddress.size() >= 10 && data.walletAddress.size() <= 200 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.timestamp is timestamp;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isNotBlocked() && isValidWithdrawal(incoming()) && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // --- REFERRAL RULES ---
    match /referrals/{referralId} {
      allow read: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().referredUserId == request.auth.uid));
      allow create: if isSignedIn() && isNotBlocked();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
